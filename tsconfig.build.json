{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "composite": true,
        "noEmit": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "declarationMap": true,
        "declarationDir": "./dist",
        "outDir": "./dist",
        "sourceMap": false,
        "inlineSources": false,
        "inlineSourceMap": false,
        "types": ["node"],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "packageConfig.ts",
        "package.json",
        "vite.config.ts"
    ],
    "exclude": ["dist", "node-modules"]
}
