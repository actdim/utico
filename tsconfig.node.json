{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "outDir": "out",
        "types": ["node"],
        "paths": {
            "@/*": ["src/*"]
        }
    },
    "include": [
        "packageConfig.ts",
        "package.json",
        "src/**/*.ts",
        "src/**/*.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx",
        "vite.config.ts",
        "vitest.config.ts",
        "vitest.node.config.ts",
        "vitest.setup.ts"
    ]
}
